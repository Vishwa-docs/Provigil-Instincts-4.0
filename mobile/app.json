{
  "expo": {
    "name": "ProVigil Field Inspector",
    "slug": "provigil-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0a0f1e",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "ProVigil needs camera access to inspect meter hardware."
      }
    },
    "android": {
      "package": "com.provigil.fieldinspector",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "permissions": ["CAMERA"],
      "versionCode": 1
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ProVigil to use your camera for meter inspection."
        }
      ]
    ]
  }
}

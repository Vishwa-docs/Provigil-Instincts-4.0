{
  "expo": {
    "name": "ProVigil Field Inspector",
    "slug": "provigil-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#F5F5F7",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "ProVigil needs camera access to inspect meter hardware."
      }
    },
    "android": {
      "package": "com.provigil.fieldinspector",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F5F7"
      },
      "permissions": ["CAMERA"],
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ProVigil to use your camera for meter inspection."
        }
      ]
    ]
  }
}

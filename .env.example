# =============================================================================
# Pro-Vigil Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
APP_NAME=Pro-Vigil
SECRET_KEY=change-me-to-a-random-string-in-production

# --- Database ---
# SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./data/provigil.db

# --- MQTT Broker ---
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# MQTT topic prefix for meter telemetry
MQTT_TOPIC_PREFIX=pro-vigil/meter

# --- ML Model Paths ---
MODEL_PATH=../model/exported/anomaly_model.pkl
SCALER_PATH=../model/exported/scaler.pkl
FEATURE_COLUMNS_PATH=../model/exported/feature_columns.json

# --- Anomaly Detection Thresholds ---
ANOMALY_THRESHOLD_WARNING=0.15
ANOMALY_THRESHOLD_CRITICAL=0.35

# --- Scoring ---
# How often to run the scoring cycle (in seconds)
SCORING_INTERVAL_SECONDS=30

# --- Simulator ---
SIMULATOR_API_URL=http://localhost:8000
SIMULATOR_MQTT_HOST=localhost
SIMULATOR_MQTT_PORT=1883

# --- Dashboard ---
VITE_API_URL=http://localhost:8000/api

# --- LLM Provider / Azure OpenAI ---
LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# --- Email / SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
ALERT_RECIPIENTS=

# --- ESP32 Edge Device (for reference, configured in edge/firmware/config.h) ---
# WIFI_SSID=your_wifi_ssid
# WIFI_PASSWORD=your_wifi_password
# MQTT_BROKER_IP=your_laptop_ip
